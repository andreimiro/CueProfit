# ──────────────────────────────────────────────────────────────────────────
# CueProfit — environment variable template.
# Copy to `.env` (gitignored) and fill in. Per-environment values live in
# Vercel (web) and GCP Secret Manager (api/workers); this file documents them.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Public (safe for browser). NEXT_PUBLIC_* are exposed to the Next.js client.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Server-only. NEVER ship to the browser. Used by FastAPI + workers (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Workers/API also read this alias (falls back to NEXT_PUBLIC_SUPABASE_URL if unset)
SUPABASE_URL=https://<project-ref>.supabase.co
# Direct Postgres connection (workers / migrations).
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Google OAuth — APP LOGIN (Supabase Auth social provider) ─────────────────
# Configured in the Supabase dashboard, listed here for reference.
GOOGLE_OAUTH_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<client-secret>

# ── Google OAuth — DATA CONNECTIONS (our own offline flow) ───────────────────
# Separate flow that requests access_type=offline for Ads + Merchant refresh tokens.
GOOGLE_ADS_OAUTH_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_ADS_OAUTH_CLIENT_SECRET=<client-secret>
# Separate redirect for Merchant Center OAuth (register in Google Cloud Console).
# Defaults to the Ads redirect with /merchant/ instead of /google/ when unset.
GOOGLE_MERCHANT_OAUTH_REDIRECT_URI=https://app.captioncue.shop/api/connect/merchant/callback
# Enable in GCP: merchantapi.googleapis.com + shoppingcontent.googleapis.com
# (Content API is used as fallback when Merchant API returns 401 before MC developer registration).

# ── Google Ads API ───────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=<developer-token>
GOOGLE_ADS_LOGIN_CUSTOMER_ID=<mcc-customer-id-no-dashes>

# ── Workers (Cloud Run Jobs) ────────────────────────────────────────────────
# Job name in GCP (not the full resource path). API triggers it after connect.
WORKERS_CLOUD_RUN_JOB=cueprofit-workers
# Local dev: spawn worker subprocess after OAuth (requires cueprofit-workers on PATH)
WORKERS_INLINE_SYNC=true
# Optional cron (UTC) when using services/workers/scripts/deploy-gcp.sh scheduler setup
WORKERS_CRON_SCHEDULE=0 5 * * *

GCP_PROJECT_ID=cueprofit-dev
GCP_REGION=europe-west1
# Cloud KMS key used to envelope-encrypt stored OAuth refresh tokens.
KMS_KEY_NAME=projects/cueprofit-dev/locations/europe-west1/keyRings/cueprofit/cryptoKeys/oauth-tokens

# ── OpenRouter (AI layer) ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=<key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Per-task model routing (override per environment).
OPENROUTER_MODEL_COPILOT=anthropic/claude-sonnet-4
OPENROUTER_MODEL_CHEAP=anthropic/claude-haiku-4
OPENROUTER_APP_URL=https://app.cueprofit.com
OPENROUTER_APP_TITLE=CueProfit

# ── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<sk>
STRIPE_WEBHOOK_SECRET=<whsec>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<pk>

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
# Public base URL of the app (used by the marketing landing page to link into
# the app). Set to the app subdomain in prod, e.g. https://app.captioncue.shop
NEXT_PUBLIC_APP_URL=http://localhost:3000
PYTHON_API_URL=http://localhost:8000
PYTHON_API_INTERNAL_TOKEN=<shared-secret-web-to-api>
# Dedicated HMAC secret for the OAuth connect-flow state. MUST differ from the
# internal token in production (required outside development).
OAUTH_STATE_SECRET=<random-32-byte-secret>
